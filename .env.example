# =============================================================================
# Cassava Theater — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# The .env file is NOT committed to git (see .gitignore).

# --- HTTP Server ---
# The built-in HTTP server for remote control and media streaming.
# Default: 5000
# PORT=5000

# --- LibreTranslate ---
# URL of the LibreTranslate server for subtitle translation.
# The app spawns its own libretranslate process by default.
# Set this if you want to use an external server instead.
# LIBRETRANSLATE_URL=http://localhost:5000

# --- Ollama (AI/LLM) ---
# URL of the Ollama server for subtitle generation and language learning.
# Default: http://localhost:11434
# OLLAMA_API_URL=http://localhost:11434

# --- TheMovieDB API ---
# API key for fetching movie/TV metadata.
# TMDB_API_KEY=your_api_key_here